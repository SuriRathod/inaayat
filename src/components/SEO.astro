---
interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: Date;
  author?: string;
  canonical?: string;
}

const {
  title,
  description,
  image,
  type = 'website',
  publishedTime,
  author = 'Suri Rathod',
  canonical
} = Astro.props;

const base = import.meta.env.BASE_URL;
const siteUrl = 'https://surirathod.github.io/inaayat';

// Smart defaults
const defaultTitle = 'Inaayat — Poetry & Reflections';
const defaultDescription = 'An expression of reality — Words woven from moments of reflection, capturing the quiet beauty and profound truth of everyday existence.';
const defaultImage = '/inaayat/images/poems/aksar.jpeg';

// Final values (use props or defaults)
const pageTitle = title ? `${title} — Inaayat` : defaultTitle;
const pageDescription = description || defaultDescription;
const pageImage = image ? (image.startsWith('http') ? image : `${siteUrl}${image}`) : `${siteUrl}${defaultImage}`;
const pageUrl = canonical || `${siteUrl}${Astro.url.pathname}`;

// Truncate description to 160 chars for SEO
const truncatedDescription = pageDescription.length > 160 
  ? pageDescription.substring(0, 157) + '...' 
  : pageDescription;
---

<!-- Essential SEO -->
<title>{pageTitle}</title>
<meta name="description" content={truncatedDescription}>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="author" content={author}>
<link rel="canonical" href={pageUrl}>

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type}>
<meta property="og:url" content={pageUrl}>
<meta property="og:title" content={pageTitle}>
<meta property="og:description" content={truncatedDescription}>
<meta property="og:image" content={pageImage}>
<meta property="og:site_name" content="Inaayat">
<meta property="og:locale" content="en_US">
{publishedTime && <meta property="article:published_time" content={publishedTime.toISOString()}>}
{author && <meta property="article:author" content={author}>}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:url" content={pageUrl}>
<meta name="twitter:title" content={pageTitle}>
<meta name="twitter:description" content={truncatedDescription}>
<meta name="twitter:image" content={pageImage}>
<meta name="twitter:creator" content="@suri_rathore_">

<!-- Additional SEO -->
<meta name="robots" content="index, follow">
<meta name="googlebot" content="index, follow">

<!-- Structured Data (JSON-LD) -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": type === 'article' ? 'CreativeWork' : 'WebSite',
  "name": pageTitle,
  "description": truncatedDescription,
  "url": pageUrl,
  "image": pageImage,
  ...(type === 'article' && {
    "author": {
      "@type": "Person",
      "name": author
    },
    "datePublished": publishedTime?.toISOString(),
    "inLanguage": "en-US"
  })
})} />