---
// SIMPLEST WORKING SOLUTION
// No backend, no iframe, no popup - just clean UX
---

<div class="newsletter-section">
    <div class="newsletter-container">
        <h3 class="newsletter-title">Stay Updated</h3>
        <p class="newsletter-description">
            Get new poems delivered to your inbox. No spam, just poetry.
        </p>
        
        <form id="newsletter-form" class="newsletter-form">
            <input 
                type="email" 
                id="newsletter-email"
                name="email"
                placeholder="your@email.com"
                required
                class="newsletter-input"
            />
            <button type="submit" class="newsletter-button">
                Subscribe
            </button>
        </form>
        
        <!-- Helpful note about the redirect -->
        <div class="newsletter-redirect-note">
            <p class="redirect-note-text">
                <strong>Quick heads-up:</strong> Clicking Subscribe will take you to Substack to confirm. 
                After subscribing, use your browser's back button to return here. It's a small detour 
                for a small, growing newsletter — thank you for bearing with me! 💙
            </p>
        </div>
        
        <p class="newsletter-note">
            Unsubscribe anytime. We respect your privacy.
        </p>
    </div>
</div>

<style>
    .newsletter-section {
        background: var(--bg-secondary);
        border: 1px solid var(--border-subtle);
        padding: 3rem 2rem;
        margin: 3rem 0;
        text-align: center;
    }
    
    .newsletter-container {
        max-width: 28rem;
        margin: 0 auto;
    }
    
    .newsletter-title {
        font-family: var(--serif);
        font-size: 1.875rem;
        font-weight: 300;
        color: var(--text-primary);
        margin-bottom: 0.75rem;
    }
    
    .newsletter-description {
        color: var(--text-secondary);
        font-size: 1rem;
        margin-bottom: 2rem;
        line-height: 1.6;
    }
    
    .newsletter-form {
        display: flex;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }
    
    .newsletter-input {
        flex: 1;
        background: var(--bg-primary);
        border: 1px solid var(--border-subtle);
        color: var(--text-primary);
        padding: 0.875rem 1rem;
        font-size: 0.875rem;
        transition: border-color 0.2s;
        font-family: var(--sans);
    }
    
    .newsletter-input:focus {
        outline: none;
        border-color: var(--accent-blue);
    }
    
    .newsletter-input::placeholder {
        color: var(--text-muted);
    }
    
    .newsletter-button {
        background: var(--accent-blue);
        color: white;
        border: none;
        padding: 0.875rem 1.5rem;
        font-size: 0.875rem;
        font-weight: 500;
        cursor: pointer;
        transition: background 0.2s;
        white-space: nowrap;
    }
    
    .newsletter-button:hover {
        background: #4184e4;
    }
    
    .newsletter-note {
        color: var(--text-muted);
        font-size: 0.75rem;
        margin-top: 1rem;
    }
    
    .newsletter-redirect-note {
        background: rgba(94, 163, 245, 0.1);
        border-left: 3px solid var(--accent-blue);
        border-radius: 4px;
        padding: 1rem;
        margin: 1.5rem 0 0.5rem 0;
        text-align: left;
    }
    
    .redirect-note-text {
        color: var(--text-secondary);
        font-size: 0.875rem;
        line-height: 1.6;
        margin: 0;
    }
    
    .redirect-note-text strong {
        color: var(--text-primary);
    }
    
    @media (max-width: 640px) {
        .newsletter-section {
            padding: 2rem 1rem;
        }
        
        .newsletter-form {
            flex-direction: column;
        }
        
        .newsletter-button {
            width: 100%;
        }
    }
</style>

<script is:raw>
    const form = document.getElementById('newsletter-form');
    const emailInput = document.getElementById('newsletter-email');
    
    form?.addEventListener('submit', (e) => {
        e.preventDefault();
        
        if (!emailInput) return;
        
        const email = emailInput.value.trim();
        
        if (!email || !email.includes('@')) {
            alert('Please enter a valid email address');
            return;
        }
        
        // Open Substack subscribe page with email pre-filled
        // This is the ONLY way that actually works with Substack
        const substackUrl = `https://surirathod.substack.com/subscribe?email=${encodeURIComponent(email)}`;
        
        // Save current scroll position
        const scrollPos = window.scrollY;
        
        // Open in same window
        window.location.href = substackUrl;
        
        // Note: User will be redirected to Substack, confirm subscription, 
        // then can click "Continue reading" to return to your site
    });
</script>

<!-- 
SETUP:
1. Change "surirathod.substack.com" to YOUR Substack (line 121)
2. That's it!

HOW IT WORKS:
- User enters email
- Clicks Subscribe  
- Redirects to Substack with email pre-filled
- User confirms subscription
- User clicks "Continue reading" to return to your site

This is the cleanest solution that ACTUALLY WORKS with Substack's restrictions.
-->