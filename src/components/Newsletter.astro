---

---

<div class="newsletter-section">
    <div class="newsletter-container">
        <h3 class="newsletter-title">Stay Updated</h3>
        <p class="newsletter-description">
            Get new poems delivered to your inbox. No spam, just poetry.
        </p>
        
        <form id="newsletter-form" class="newsletter-form">
            <input 
                type="email" 
                id="newsletter-email"
                placeholder="your@email.com"
                required
                class="newsletter-input"
            />
            <button type="submit" id="newsletter-button" class="newsletter-button">
                Subscribe
            </button>
        </form>

        <div id="newsletter-toast" class="newsletter-toast">
            Opening subscription…
        </div>
        
        <p class="newsletter-note">
            Unsubscribe anytime. We respect your privacy.
        </p>
    </div>
</div>

<style>
.newsletter-section {
    background: var(--bg-secondary);
    border: 1px solid var(--border-subtle);
    padding: 3rem 2rem;
    margin: 3rem 0;
    text-align: center;
}

.newsletter-container {
    max-width: 28rem;
    margin: 0 auto;
}

.newsletter-title {
    font-family: var(--serif);
    font-size: 1.875rem;
    font-weight: 300;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
}

.newsletter-description {
    color: var(--text-secondary);
    font-size: 1rem;
    margin-bottom: 2rem;
    line-height: 1.6;
}

.newsletter-form {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1rem;
}

.newsletter-input {
    flex: 1;
    background: var(--bg-primary);
    border: 1px solid var(--border-subtle);
    color: var(--text-primary);
    caret-color: var(--text-primary);
    padding: 0.875rem 1rem;
    font-size: 0.875rem;
    font-family: var(--sans);
}

.newsletter-button {
    background: var(--accent-blue);
    color: white;
    border: none;
    padding: 0.875rem 1.5rem;
    font-size: 0.875rem;
    cursor: pointer;
}

.newsletter-toast {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    background: var(--bg-primary);
    color: var(--text-primary);
    border: 1px solid var(--border-subtle);
    padding: 0.75rem 1.25rem;
    font-size: 0.875rem;
    opacity: 0;
    transition: all 0.4s ease;
}

.newsletter-toast.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
}

@media (max-width: 640px) {
    .newsletter-form {
        flex-direction: column;
    }
}
</style>

<script is:raw>
const form = document.getElementById("newsletter-form");
const emailInput = document.getElementById("newsletter-email");
const toast = document.getElementById("newsletter-toast");
const button = document.getElementById("newsletter-button");

if (form) {
    form.addEventListener("submit", (e) => {
        e.preventDefault();

        const email = emailInput.value.trim();
        if (!email) return;

        // Open Substack subscribe page with prefilled email
        const url = `https://surirathod.substack.com/subscribe?email=${encodeURIComponent(email)}`;

        const width = 600;
        const height = 700;
        const left = (window.innerWidth - width) / 2;
        const top = (window.innerHeight - height) / 2;

        window.open(
            url,
            "substack-popup",
            `scrollbars=yes,width=${width},height=${height},top=${top},left=${left}`
        );

        // UI feedback
        button.textContent = "Opening...";
        toast.classList.add("show");

        setTimeout(() => {
            button.textContent = "Subscribe";
            toast.classList.remove("show");
            emailInput.value = "";
        }, 3000);
    });
}
</script>