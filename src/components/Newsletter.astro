---

---

<div class="newsletter-section">
    <div class="newsletter-container">
        <h3 class="newsletter-title">Stay Updated</h3>
        <p class="newsletter-description">
            Get new poems delivered to your inbox. No spam, just poetry.
        </p>
        
        <form 
            action="https://surirathod.substack.com/api/v1/free" 
            method="post"
            target="hidden-iframe"
            id="newsletter-form"
            class="newsletter-form"
        >
            <input 
                type="email" 
                name="email"
                id="newsletter-email"
                placeholder="your@email.com"
                required
                class="newsletter-input"
            />
            <button type="submit" id="newsletter-button" class="newsletter-button">
                Subscribe
            </button>
        </form>

        <iframe name="hidden-iframe" style="display:none;"></iframe>

        <div id="newsletter-toast" class="newsletter-toast">
            <span class="toast-text">You’re subscribed — check your inbox ✉️</span>
        </div>
        
        <p class="newsletter-note">
            Unsubscribe anytime. We respect your privacy.
        </p>
    </div>
</div>

<style>
    .newsletter-section {
        background: var(--bg-secondary);
        border: 1px solid var(--border-subtle);
        padding: 3rem 2rem;
        margin: 3rem 0;
        text-align: center;
    }
    
    .newsletter-container {
        max-width: 28rem;
        margin: 0 auto;
    }
    
    .newsletter-title {
        font-family: var(--serif);
        font-size: 1.875rem;
        font-weight: 300;
        color: var(--text-primary);
        margin-bottom: 0.75rem;
    }
    
    .newsletter-description {
        color: var(--text-secondary);
        font-size: 1rem;
        margin-bottom: 2rem;
        line-height: 1.6;
    }
    
    .newsletter-form {
        display: flex;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }
    
    .newsletter-input {
        flex: 1;
        background: var(--bg-primary);
        border: 1px solid var(--border-subtle);
        color: var(--text-primary);
        padding: 0.875rem 1rem;
        font-size: 0.875rem;
        transition: border-color 0.2s, box-shadow 0.2s;
        font-family: var(--sans);
    }

    .newsletter-input:focus {
        outline: none;
        border-color: var(--accent-blue);
        box-shadow: 0 0 0 1px var(--accent-blue);
    }
    
    .newsletter-input::placeholder {
        color: var(--text-muted);
    }
    
    .newsletter-button {
        background: var(--accent-blue);
        color: white;
        border: none;
        padding: 0.875rem 1.5rem;
        font-size: 0.875rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s ease;
        white-space: nowrap;
    }
    
    .newsletter-button:hover {
        background: #4184e4;
        transform: translateY(-1px);
    }

    .newsletter-button.loading {
        opacity: 0.7;
        cursor: not-allowed;
    }
    
    .newsletter-note {
        color: var(--text-muted);
        font-size: 0.75rem;
        margin-top: 1rem;
    }

    /* ✨ Toast (polished, subtle, poetic) */
    .newsletter-toast {
        position: fixed;
        bottom: 2rem;
        left: 50%;
        transform: translateX(-50%) translateY(20px);
        background: var(--bg-primary);
        color: var(--text-primary);
        border: 1px solid var(--border-subtle);
        padding: 0.75rem 1.25rem;
        font-size: 0.875rem;
        opacity: 0;
        pointer-events: none;
        transition: all 0.4s ease;
        backdrop-filter: blur(6px);
    }

    .newsletter-toast.show {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
    }

    .toast-text {
        font-family: var(--sans);
        letter-spacing: 0.2px;
    }

    @media (max-width: 640px) {
        .newsletter-section {
            padding: 2rem 1rem;
        }
        
        .newsletter-form {
            flex-direction: column;
        }
        
        .newsletter-button {
            width: 100%;
        }
    }
</style>

<script is:raw>
window.addEventListener("DOMContentLoaded", () => {
    const form = document.getElementById("newsletter-form");
    const emailInput = document.getElementById("newsletter-email");
    const toast = document.getElementById("newsletter-toast");
    const button = document.getElementById("newsletter-button");

    if (form && emailInput && toast && button) {
        form.addEventListener("submit", () => {
            // Loading state
            button.classList.add("loading");
            button.textContent = "Subscribing...";

            // Show toast after slight delay (feels more natural)
            setTimeout(() => {
                toast.classList.add("show");
            }, 400);

            // Reset form + button
            setTimeout(() => {
                emailInput.value = "";
                button.classList.remove("loading");
                button.textContent = "Subscribe";
            }, 1200);

            // Hide toast
            setTimeout(() => {
                toast.classList.remove("show");
            }, 3500);
        });
    }
});
</script>