---
const substackUrl = "https://surirathod.substack.com";
---

<div class="newsletter-section">
    <div class="newsletter-container">
        <h3 class="newsletter-title">Stay Updated</h3>
        <p class="newsletter-description">
            Get new poems delivered to your inbox. No spam, just poetry.
        </p>
        
        <form id="newsletter-form" class="newsletter-form">
            <input 
                type="email" 
                name="email"
                id="newsletter-email"
                placeholder="your@email.com"
                required
                class="newsletter-input"
            />
            <button type="submit" class="newsletter-button">
                Subscribe
            </button>
        </form>

        <!-- Toast -->
        <div id="newsletter-toast" class="newsletter-toast">Subscribed successfully!</div>
        
        <p class="newsletter-note">
            Unsubscribe anytime. We respect your privacy.
        </p>
    </div>
</div>

<style>
    /* your existing styles stay the same */

    .newsletter-toast {
        display: none;
        margin-top: 1rem;
        padding: 0.75rem 1rem;
        background: var(--accent-blue);
        color: white;
        border-radius: 4px;
        font-size: 0.875rem;
        animation: fadeInOut 3s ease forwards;
    }

    @keyframes fadeInOut {
        0% { opacity: 0; transform: translateY(10px); }
        10% { opacity: 1; transform: translateY(0); }
        90% { opacity: 1; }
        100% { opacity: 0; transform: translateY(10px); }
    }
</style>

<script>
    const form = document.getElementById("newsletter-form");
    const emailInput = document.getElementById("newsletter-email") as HTMLInputElement | null;
    const toast = document.getElementById("newsletter-toast");

    if (form && emailInput && toast) {
        form.addEventListener("submit", async (e) => {
            e.preventDefault();

            const email = emailInput.value.trim();
            if (!email) return;

            try {
                await fetch("https://surirathod.substack.com/api/v1/free", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ email })
                });

                toast.style.display = "block";
                emailInput.value = "";

                setTimeout(() => {
                    toast.style.display = "none";
                }, 3000);

            } catch (err) {
                console.error("Subscription error:", err);
            }
        });
    }
</script>
