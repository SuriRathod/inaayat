---
// Custom Newsletter Form - Styled to match your theme
// Replace SUBSTACK_URL with your actual Substack URL
const substackUrl = "https://surirathod.substack.com"; // CHANGE THIS
---

<div class="newsletter-section">
    <div class="newsletter-container">
        <h3 class="newsletter-title">Stay Updated</h3>
        <p class="newsletter-description">
            Get new poems delivered to your inbox. No spam, just poetry.
        </p>
        
        <form 
            action={`${substackUrl}/subscribe`}
            method="post"
            target="_blank"
            class="newsletter-form"
        >
            <input 
                type="email" 
                name="email"
                placeholder="your@email.com"
                required
                class="newsletter-input"
            />
            <button type="submit" class="newsletter-button">
                Subscribe
            </button>
        </form>
        
        <p class="newsletter-note">
            Unsubscribe anytime. We respect your privacy.
        </p>
    </div>
</div>

<style>
    .newsletter-section {
        background: var(--bg-secondary);
        border: 1px solid var(--border-subtle);
        padding: 3rem 2rem;
        margin: 3rem 0;
        text-align: center;
    }
    
    .newsletter-container {
        max-width: 28rem;
        margin: 0 auto;
    }
    
    .newsletter-title {
        font-family: var(--serif);
        font-size: 1.875rem;
        font-weight: 300;
        color: var(--text-primary);
        margin-bottom: 0.75rem;
    }
    
    .newsletter-description {
        color: var(--text-secondary);
        font-size: 1rem;
        margin-bottom: 2rem;
        line-height: 1.6;
    }
    
    .newsletter-form {
        display: flex;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }
    
    .newsletter-input {
        flex: 1;
        background: var(--bg-primary);
        border: 1px solid var(--border-subtle);
        color: var(--text-primary);
        padding: 0.875rem 1rem;
        font-size: 0.875rem;
        transition: border-color 0.2s;
        font-family: var(--sans);
    }
    
    .newsletter-input:focus {
        outline: none;
        border-color: var(--accent-blue);
    }
    
    .newsletter-input::placeholder {
        color: var(--text-muted);
    }
    
    .newsletter-button {
        background: var(--accent-blue);
        color: white;
        border: none;
        padding: 0.875rem 1.5rem;
        font-size: 0.875rem;
        font-weight: 500;
        cursor: pointer;
        transition: background 0.2s;
        white-space: nowrap;
    }
    
    .newsletter-button:hover {
        background: #4184e4;
    }
    
    .newsletter-note {
        color: var(--text-muted);
        font-size: 0.75rem;
        margin-top: 1rem;
    }
    
    @media (max-width: 640px) {
        .newsletter-section {
            padding: 2rem 1rem;
        }
        
        .newsletter-form {
            flex-direction: column;
        }
        
        .newsletter-button {
            width: 100%;
        }
    }
</style>

<!-- 
HOW TO SETUP:
1. Create Substack account: https://substack.com
2. Your Substack URL will be: https://yourname.substack.com
3. Replace line 3 above with your URL
4. Done! Form submits directly to Substack
-->