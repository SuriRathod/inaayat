---
import '../../styles/global.css';
import SEO from '../../components/SEO.astro';
import ScrollToTop from '../../components/ScrollToTop.astro';
import { GALLERY_TRIPS } from '../../gallery-config';

export async function getStaticPaths() {
  return GALLERY_TRIPS.map((trip) => ({
    params: { slug: trip.id },
    props: { trip },
  }));
}

const { trip } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <SEO 
      title={trip.title}
      description={trip.description}
      image={trip.coverImage}
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <style>
        body {
            background: var(--bg-primary);
            color: var(--text-primary);
        }
        
        .nav-header {
            background: rgba(15, 20, 25, 0.8);
            border-bottom: 1px solid var(--border-subtle);
        }
        
        .photo-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 1.5rem;
        }
        
        .photo-item {
            background: var(--bg-accent);
            border: 1px solid var(--border-subtle);
            overflow: hidden;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        
        .photo-item:hover {
            border-color: var(--text-secondary);
            transform: translateY(-4px);
        }
        
        .photo-item img {
            width: 100%;
            aspect-ratio: 4/3;
            object-fit: cover;
            transition: transform 0.7s ease;
        }
        
        .photo-item:hover img {
            transform: scale(1.05);
        }
        
        /* Lightbox */
        .lightbox {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(15, 20, 25, 0.95);
            z-index: 9999;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }
        
        .lightbox.active {
            display: flex;
        }
        
        .lightbox img {
            max-width: 90%;
            max-height: 90%;
            object-fit: contain;
        }
        
        .lightbox-close {
            position: absolute;
            top: 2rem;
            right: 2rem;
            background: none;
            border: none;
            color: white;
            font-size: 2rem;
            cursor: pointer;
            padding: 0.5rem;
        }
        
        .lightbox-nav {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            background: rgba(255, 255, 255, 0.1);
            border: none;
            color: white;
            font-size: 2rem;
            cursor: pointer;
            padding: 1rem;
            transition: background 0.2s;
        }
        
        .lightbox-nav:hover {
            background: rgba(255, 255, 255, 0.2);
        }
        
        .lightbox-prev {
            left: 2rem;
        }
        
        .lightbox-next {
            right: 2rem;
        }
    </style>
</head>
<body class="antialiased">
    
    <header class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md nav-header">
        <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-12">
            <div class="flex justify-between items-center h-16 sm:h-20">
                <a href="/" class="text-lg sm:text-xl font-light tracking-widest" style="font-family: var(--serif); color: var(--text-primary);">
                    INAAYAT
                </a>
                <a href="/gallery" class="text-xs sm:text-sm transition-colors inline-flex items-center gap-2" style="color: var(--text-secondary);" onmouseover="this.style.color='var(--text-primary)'" onmouseout="this.style.color='var(--text-secondary)'">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7"/>
                    </svg>
                    All Galleries
                </a>
                 <a href="/contact" class="transition-colors" style="color: var(--text-secondary);" onmouseover="this.style.color='var(--text-primary)'" onmouseout="this.style.color='var(--text-secondary)'">Contact</a>
            </div>
        </nav>
    </header>

    <section class="pt-32 pb-16 px-4 sm:px-6 lg:px-12">
        <div class="max-w-7xl mx-auto">
            <div class="text-xs uppercase tracking-widest mb-4 font-light" style="color: var(--text-muted);">
                {trip.date}
            </div>
            <h1 class="text-4xl md:text-5xl font-light mb-4" style="font-family: var(--serif); color: var(--text-primary);">
                {trip.title}
            </h1>
            <p class="text-lg font-light" style="color: var(--text-secondary);">
                {trip.description}
            </p>
        </div>
    </section>

    <section class="pb-24 px-4 sm:px-6 lg:px-12">
        <div class="max-w-7xl mx-auto">
            <div class="photo-grid">
                {trip.photos.map((photo, index) => (
                    <div class="photo-item" data-index={index}>
                        <img 
                            src={photo.src} 
                            alt={photo.alt}
                            loading="lazy"
                        />
                        {photo.caption && (
                            <div class="p-4">
                                <p class="text-sm font-light" style="color: var(--text-secondary);">
                                    {photo.caption}
                                </p>
                            </div>
                        )}
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Lightbox -->
    <div id="lightbox" class="lightbox">
        <button id="lightbox-close" class="lightbox-close">&times;</button>
        <button id="lightbox-prev" class="lightbox-nav lightbox-prev">‹</button>
        <img id="lightbox-img" src="" alt="">
        <button id="lightbox-next" class="lightbox-nav lightbox-next">›</button>
    </div>

    <footer class="py-12" style="border-top: 1px solid var(--border-subtle);">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-12 text-center">
            <a href="/gallery" class="inline-flex items-center gap-2 text-sm transition-colors mb-6" style="color: var(--text-secondary);" onmouseover="this.style.color='var(--text-primary)'" onmouseout="this.style.color='var(--text-secondary)'">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7"/>
                </svg>
                Back to all galleries
            </a>
            <p class="text-sm font-light" style="color: var(--text-muted);">
                © 2017-{new Date().getFullYear()} · All Rights Reserved
            </p>
        </div>
    </footer>

    <ScrollToTop />

    <script define:vars={{ photos: trip.photos }}>
        let currentIndex = 0;
        
        const lightbox = document.getElementById('lightbox');
        const lightboxImg = document.getElementById('lightbox-img');
        const lightboxClose = document.getElementById('lightbox-close');
        const lightboxPrev = document.getElementById('lightbox-prev');
        const lightboxNext = document.getElementById('lightbox-next');
        const photoItems = document.querySelectorAll('.photo-item');
        
        function openLightbox(index) {
            currentIndex = index;
            lightboxImg.src = photos[currentIndex].src;
            lightbox.classList.add('active');
        }
        
        function closeLightbox() {
            lightbox.classList.remove('active');
        }
        
        function showPrev() {
            currentIndex = (currentIndex - 1 + photos.length) % photos.length;
            lightboxImg.src = photos[currentIndex].src;
        }
        
        function showNext() {
            currentIndex = (currentIndex + 1) % photos.length;
            lightboxImg.src = photos[currentIndex].src;
        }
        
        photoItems.forEach((item, index) => {
            item.addEventListener('click', () => openLightbox(index));
        });
        
        lightboxClose.addEventListener('click', closeLightbox);
        lightboxPrev.addEventListener('click', showPrev);
        lightboxNext.addEventListener('click', showNext);
        
        lightbox.addEventListener('click', (e) => {
            if (e.target === lightbox) closeLightbox();
        });
        
        document.addEventListener('keydown', (e) => {
            if (!lightbox.classList.contains('active')) return;
            
            if (e.key === 'Escape') closeLightbox();
            if (e.key === 'ArrowLeft') showPrev();
            if (e.key === 'ArrowRight') showNext();
        });
    </script>

</body>
</html>
