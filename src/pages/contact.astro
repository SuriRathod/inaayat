---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import ScrollToTop from '../components/ScrollToTop.astro';
import Newsletter from '../components/Newsletter.astro';
import Navigation from '../components/Navigation.astro';
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <SEO 
      title="Contact"
      description="Get in touch with Inaayat — Share feedback, request permissions, or connect about poetry and writing."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <style>
        body {
            background: var(--bg-primary);
            color: var(--text-primary);
        }
        
        .nav-header {
            background: rgba(15, 20, 25, 0.8);
            border-bottom: 1px solid var(--border-subtle);
        }
        
        .contact-box {
            background: var(--bg-accent);
            border: 1px solid var(--border-subtle);
            padding: 2rem;
            margin: 2rem 0;
        }
        
        .contact-method {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 1.5rem;
            background: var(--bg-secondary);
            border: 1px solid var(--border-subtle);
            margin-bottom: 1rem;
            transition: all 0.2s;
        }
        
        .contact-method:hover {
            border-color: var(--text-secondary);
        }
        
        .contact-icon {
            width: 2.5rem;
            height: 2.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--bg-accent);
            border-radius: 50%;
            color: var(--accent-blue);
        }
        
        .contact-info h3 {
            font-family: var(--serif);
            font-size: 1.125rem;
            font-weight: 300;
            color: var(--text-primary);
            margin-bottom: 0.25rem;
        }
        
        .contact-info p {
            color: var(--text-secondary);
            font-size: 0.875rem;
        }
        
        .contact-info a {
            color: var(--accent-blue);
            text-decoration: none;
            transition: color 0.2s;
        }
        
        .contact-info a:hover {
            color: var(--text-primary);
        }
    </style>
</head>
<body class="antialiased">

    <Navigation />

    <article class="pt-32 pb-24 px-4 sm:px-6 lg:px-12">
        <div class="max-w-3xl mx-auto">
            
            <div class="mb-16 text-center">
                <h1 class="text-4xl md:text-6xl font-light mb-6 leading-tight" style="font-family: var(--serif); color: var(--text-primary);">
                    Get in Touch
                </h1>
                <p class="text-lg font-light" style="color: var(--text-secondary);">
                    I'd love to hear from you
                </p>
            </div>

            <div class="mb-12">
                <p class="text-lg leading-relaxed mb-6" style="color: var(--text-secondary);">
                    Whether you want to share feedback, request permission to use my work, discuss a collaboration, 
                    or simply connect over poetry — I'm here to listen.
                </p>
            </div>

            <div class="contact-box">
                <h2 class="text-2xl font-light mb-6" style="font-family: var(--serif); color: var(--text-primary);">
                    How to Reach Me
                </h2>

                <!-- Email -->
                <div class="contact-method">
                    <div class="contact-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                            <polyline points="22,6 12,13 2,6"/>
                        </svg>
                    </div>
                    <div class="contact-info">
                        <h3>Email</h3>
                        <p><a href="mailto:contact@inaayat.art">hello@inaayat.art</a></p>
                        <!-- REPLACE contact@inaayat.art with your actual email -->
                    </div>
                </div>

                <!-- Instagram -->
                <div class="contact-method">
                    <div class="contact-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                        </svg>
                    </div>
                    <div class="contact-info">
                        <h3>Instagram</h3>
                        <p><a href="https://www.instagram.com/_._.inaayat._._/" target="_blank">@_._.inaayat._._</a></p>
                    </div>
                </div>

                <!-- Twitter/X -->
                <div class="contact-method">
                    <div class="contact-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                        </svg>
                    </div>
                    <div class="contact-info">
                        <h3>X (Twitter)</h3>
                        <p><a href="https://x.com/suri_rathore_?s=21" target="_blank">@suri_rathore_</a></p>
                    </div>
                </div>
            </div>

            <div class="mt-12">
                <h2 class="text-2xl font-light mb-4" style="font-family: var(--serif); color: var(--text-primary);">
                    What You Can Reach Out About
                </h2>
                <ul class="space-y-3" style="color: var(--text-secondary); line-height: 1.8;">
                    <li>✍️ Feedback on poems or stories</li>
                    <li>📝 Permission to use or share my work</li>
                    <li>🤝 Collaboration opportunities</li>
                    <li>📚 Publication or feature requests</li>
                    <li>💭 General thoughts about poetry and writing</li>
                    <li>🎤 Speaking or reading invitations</li>
                </ul>
            </div>

            <div class="mt-12 p-6" style="background: var(--bg-accent); border-left: 3px solid var(--accent-blue);">
                <p class="text-sm" style="color: var(--text-secondary); line-height: 1.8;">
                    <strong style="color: var(--text-primary);">Response Time:</strong> 
                    I typically respond within 2-3 business days. If you don't hear back, feel free to send a gentle reminder — 
                    sometimes messages get lost in the shuffle.
                </p>
            </div>

        </div>
    </article>

    <Newsletter />

    <footer class="py-12" style="border-top: 1px solid var(--border-subtle);">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-12">
            <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-sm font-light" style="color: var(--text-muted);">
                <div class="flex items-center gap-2">
                    <p>© 2017-{new Date().getFullYear()} · All Rights Reserved</p>
                    <span>·</span>
                    <a href="/copyright" class="transition-colors" style="color: var(--text-muted);" onmouseover="this.style.color='var(--text-primary)'" onmouseout="this.style.color='var(--text-muted)'">Copyright Policy</a>
                </div>
                <p>Inaayat</p>
            </div>
        </div>
    </footer>

    <ScrollToTop />

</body>
</html>
