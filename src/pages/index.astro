---
import { getCollection } from 'astro:content';
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import Search from '../components/Search.astro';
import ScrollToTop from '../components/ScrollToTop.astro';

const siteTitle = "Inaayat";
const allPoems = await getCollection('poems');
const sortedPoems = allPoems.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const recentPoems = sortedPoems.slice(0, 6);
const allStories = await getCollection('stories');
const sortedStories = allStories.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const featuredStories = sortedStories.slice(0, 2);
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <SEO 
      title="Inaayat — Poetry & Reflections"
      description="An expression of reality — Words woven from moments of reflection, capturing the quiet beauty and profound truth of everyday existence."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <style>
        body {
            background: var(--bg-primary);
            color: var(--text-primary);
        }
        
        .nav-header {
            background: rgba(15, 20, 25, 0.8);
            border-bottom: 1px solid var(--border-subtle);
        }
        
        .tag-badge {
            background: var(--bg-accent);
            border: 1px solid var(--border-subtle);
            color: var(--text-secondary);
        }
        
        .btn-primary {
            background: var(--accent-blue);
            color: white;
        }
        
        .btn-primary:hover {
            background: #4184e4;
        }
        
        .btn-secondary {
            border: 1px solid var(--border-subtle);
            color: var(--text-primary);
        }
        
        .btn-secondary:hover {
            border-color: var(--text-secondary);
            background: var(--bg-accent);
        }
        
        .stats-section {
            background: var(--bg-secondary);
            border-top: 1px solid var(--border-subtle);
            border-bottom: 1px solid var(--border-subtle);
        }
        
        .about-section {
            background: var(--bg-secondary);
            border-top: 1px solid var(--border-subtle);
            border-bottom: 1px solid var(--border-subtle);
        }
        
        .image-card {
            background: var(--bg-accent);
            border: 1px solid var(--border-subtle);
        }
        
        .footer-border {
            border-top: 1px solid var(--border-subtle);
        }
    </style>
</head>
<body class="antialiased">
    
    <header class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md nav-header">
        <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-12">
            <div class="flex justify-between items-center h-16 sm:h-20">
                <a href="/" class="text-lg sm:text-xl font-light tracking-widest" style="font-family: var(--serif); color: var(--text-primary);">
                    INAAYAT
                </a>
                <div class="flex gap-4 sm:gap-8 text-xs sm:text-sm font-light items-center">
                    
                    <a href="/poems" class="transition-colors" style="color: var(--text-secondary);" onmouseover="this.style.color='var(--text-primary)'" onmouseout="this.style.color='var(--text-secondary)'">Poems</a>
                    <a href="/stories" class="transition-colors" style="color: var(--text-secondary);" onmouseover="this.style.color='var(--text-primary)'" onmouseout="this.style.color='var(--text-secondary)'">Stories</a>
                    <a href="/gallery" class="transition-colors" style="color: var(--text-secondary);" onmouseover="this.style.color='var(--text-primary)'" onmouseout="this.style.color='var(--text-secondary)'">Gallery</a>
                    <a href="/about" class="transition-colors" style="color: var(--text-secondary);" onmouseover="this.style.color='var(--text-primary)'" onmouseout="this.style.color='var(--text-secondary)'">About</a>
                    <Search />
                </div>
            </div>
        </nav>
    </header>

    <section class="min-h-screen flex items-center justify-center px-6 pt-20">
        <div class="max-w-5xl mx-auto text-center">
            <div class="inline-block px-4 py-2 rounded-full text-xs uppercase tracking-widest mb-8 tag-badge">
                Poetry & Reflections
            </div>
            
            <h1 class="text-5xl md:text-7xl lg:text-8xl font-light mb-8 leading-tight tracking-tight" style="font-family: var(--serif); color: var(--text-primary);">
                An Expression<br/>of Reality
            </h1>
            
            <p class="text-lg md:text-xl max-w-2xl mx-auto mb-12 leading-relaxed font-light" style="color: var(--text-secondary);">
                Words woven from moments of reflection, capturing the quiet beauty 
                and profound truth of everyday existence.
            </p>
            
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a href="/#poetry" class="inline-block px-8 py-3 text-sm font-medium transition-all btn-primary">
                    Explore Poetry →
                </a>
                <a href="https://www.instagram.com/_._.inaayat._._/" target="_blank" class="inline-block px-8 py-3 text-sm font-medium transition-all btn-secondary">
                    Instagram
                </a>
            </div>
        </div>
    </section>

    <section class="py-16 stats-section">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-12">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-center">
                <div>
                    <div class="text-4xl font-light mb-2" style="font-family: var(--serif); color: var(--text-primary);">{sortedPoems.length}+</div>
                    <div class="text-sm uppercase tracking-wider" style="color: var(--text-muted);">Poems Published</div>
                </div>
                <div>
                    <div class="text-4xl font-light mb-2" style="font-family: var(--serif); color: var(--text-primary);">2017</div>
                    <div class="text-sm uppercase tracking-wider" style="color: var(--text-muted);">Writing Since</div>
                </div>
                <div>
                    <div class="text-4xl font-light mb-2" style="font-family: var(--serif); color: var(--text-primary);">∞</div>
                    <div class="text-sm uppercase tracking-wider" style="color: var(--text-muted);">Stories to Tell</div>
                </div>
            </div>
        </div>
    </section>

    <section id="poetry" class="py-24 scroll-mt-20">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-12">
            
            <div class="mb-16">
                <h2 class="text-4xl md:text-5xl font-light mb-4" style="font-family: var(--serif); color: var(--text-primary);">Poetry Collection</h2>
                <p class="font-light" style="color: var(--text-secondary);">A journey through words, emotions, and moments.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
                {recentPoems.map((poem) => (
                    <article class="group">
                        <a href={"/poems/" + poem.slug} class="block">
                            
                            {poem.data.image && (
                                <div class="aspect-[4/3] mb-6 overflow-hidden image-card">
                                    <img 
                                        src={poem.data.image} 
                                        alt={poem.data.title}
                                        class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700 ease-out opacity-70 group-hover:opacity-90"
                                    />
                                </div>
                            )}
                            
                            <div class="space-y-4">
                                <time class="text-xs uppercase tracking-widest font-light" style="color: var(--text-muted);">
                                    {poem.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                                </time>
                                
                                <h3 class="text-2xl font-light leading-tight group-hover:opacity-70 transition-opacity" style="font-family: var(--serif); color: var(--text-primary);">
                                    {poem.data.title}
                                </h3>
                                
                                <p class="text-sm leading-relaxed line-clamp-3 font-light" style="color: var(--text-secondary);">
                                    {poem.data.excerpt.replace(/<p>|<\/p>|<br>/g, ' ').replace(/\s+/g, ' ').trim()}
                                </p>
                                
                                <div class="flex items-center text-sm font-medium group-hover:gap-2 transition-all" style="color: var(--text-primary);">
                                    Read poem
                                    <svg class="w-4 h-4 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                                    </svg>
                                </div>
                            </div>
                        </a>
                    </article>
                ))}
            </div>
            
            <div class="text-center mt-16">
                <a href="/poems" class="inline-block px-8 py-3 text-sm font-medium transition-all btn-secondary">
                    View All {sortedPoems.length} Poems →
                </a>
            </div>
        </div>
    </section>

    <section class="py-16 border-y" style="border-color: var(--border-subtle);">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-12">
            <div class="max-w-3xl mx-auto text-center">
                
                <h3 class="text-2xl font-light mb-4" style="font-family: var(--serif); color: var(--text-primary);">
                    Follow Along on Instagram
                </h3>
                
                <p class="text-sm leading-relaxed mb-8 font-light" style="color: var(--text-secondary);">
                    New poetry posts, reels, and daily reflections. Join the journey.
                </p>
                
                <a href="https://www.instagram.com/_._.inaayat._._/" 
                   target="_blank" 
                   rel="noopener noreferrer"
                   class="inline-flex items-center gap-2 px-6 py-2.5 text-sm font-medium transition-all btn-secondary">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                    </svg>
                    @_._.inaayat._._
                </a>
                
            </div>
        </div>
    </section>

    <section class="py-24">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-12">
            
            <div class="mb-16 text-center">
                <h2 class="text-4xl md:text-5xl font-light mb-4" style="font-family: var(--serif); color: var(--text-primary);">Featured Stories</h2>
                <p class="font-light" style="color: var(--text-secondary);">Narratives and reflections</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-12 max-w-5xl mx-auto">
                {featuredStories.map((story) => (
                    <article class="group">
                        <a href={"/stories/" + story.slug} class="block">

                            {story.data.image && (
                                <div class="aspect-[16/9] mb-6 overflow-hidden image-card">
                                    <img 
                                        src={story.data.image}
                                        alt={story.data.title}
                                        class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700 ease-out opacity-70 group-hover:opacity-90"
                                    />
                                </div>
                            )}

                            <div class="space-y-4">
                                <div class="flex items-center gap-3 text-xs uppercase tracking-widest font-light" style="color: var(--text-muted);">
                                    <time>
                                        {story.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                                    </time>
                                    <span>·</span>
                                    <span>{story.data.readTime}</span>
                                </div>

                                <h3 class="text-2xl font-light leading-tight group-hover:opacity-70 transition-opacity" style="font-family: var(--serif); color: var(--text-primary);">
                                    {story.data.title}
                                </h3>

                                <p class="text-sm leading-relaxed line-clamp-3 font-light" style="color: var(--text-secondary);">
                                    {story.data.excerpt.replace(/<p>|<\/p>|<br>/g, ' ').replace(/\s+/g, ' ').trim()}
                                </p>

                                <div class="flex items-center text-sm font-medium group-hover:gap-2 transition-all" style="color: var(--text-primary);">
                                    Read story
                                    <svg class="w-4 h-4 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                                    </svg>
                                </div>
                            </div>

                        </a>
                    </article>
                ))}
            </div>

            <div class="text-center mt-16">
                <a href="/stories" class="inline-block px-8 py-3 text-sm font-medium transition-all btn-secondary">
                    Explore All Stories →
                </a>
            </div>
            
        </div>
    </section>

    <section id="about" class="py-24 about-section scroll-mt-20">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-12 text-center">
            <h2 class="text-4xl md:text-5xl font-light mb-8" style="font-family: var(--serif); color: var(--text-primary);">Writer. Dreamer. Observer.</h2>
            <p class="text-lg leading-relaxed mb-6 font-light" style="color: var(--text-secondary);">
                My writings represent my feelings about life and are an attempt to express 
                the limitless emotion in this emotionless world.
            </p>
            <p class="text-lg leading-relaxed font-light" style="color: var(--text-secondary);">
                Through poetry, I capture fleeting moments, deep reflections, and the 
                beautiful complexity of human experience.
            </p>
        </div>
    </section>

    <section id="contact" class="py-24 scroll-mt-20">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-12 text-center">
            <h2 class="text-4xl md:text-5xl font-light mb-8" style="font-family: var(--serif); color: var(--text-primary);">Let's Connect</h2>
            <p class="text-lg mb-12 font-light" style="color: var(--text-secondary);">
                Follow my journey or reach out — I'd love to hear from you.
            </p>
            
            <div class="flex flex-wrap gap-6 justify-center">
                <a href="https://www.instagram.com/_._.inaayat._._/" target="_blank" 
                   class="inline-block px-6 py-3 text-sm font-medium transition-all btn-secondary">
                    Instagram
                </a>
                <a href="https://x.com/suri_rathore_?s=21" target="_blank"
                   class="inline-block px-6 py-3 text-sm font-medium transition-all btn-secondary">
                    X (Twitter)
                </a>
                <a href="https://surirathoreblog.wordpress.com" target="_blank"
                   class="inline-block px-6 py-3 text-sm font-medium transition-all btn-secondary">
                    Blog
                </a>
            </div>
        </div>
    </section>

    <footer class="py-12" style="border-top: 1px solid var(--border-subtle);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-12">
        <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-sm font-light" style="color: var(--text-muted);">
            <div class="flex items-center gap-2">
                <p>© 2017-{new Date().getFullYear()} · All Rights Reserved</p>
                <span>·</span>
                <a href="/copyright" class="transition-colors" style="color: var(--text-muted);" onmouseover="this.style.color='var(--text-primary)'" onmouseout="this.style.color='var(--text-muted)'">Copyright Policy</a>
            </div>
            <p>Inaayat</p>
        </div>
    </div>
</footer>

    <ScrollToTop />

</body>
</html>