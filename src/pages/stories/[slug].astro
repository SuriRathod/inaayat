---
import { getCollection } from 'astro:content';
import '../../styles/global.css';
import SEO from '../../components/SEO.astro';
import ScrollToTop from '../../components/ScrollToTop.astro';
import Newsletter from '../../components/Newsletter.astro';
import Navigation from '../../components/Navigation.astro';

export async function getStaticPaths() {
  const stories = await getCollection('stories');

  // Sort newest → oldest
  const sortedStories = stories.sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
  );

  return sortedStories.map((story, index) => ({
    params: { slug: story.slug },
    props: {
      story,
      prevStory: sortedStories[index + 1] || null,
      nextStory: sortedStories[index - 1] || null,
    },
  }));
}

const { story, prevStory, nextStory } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <SEO 
      title={story.data.title}
      description={story.data.excerpt.substring(0, 160)}
      image={story.data.image}
      type="article"
      publishedTime={story.data.date}
      author="Suri Rathod"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">

    <style>
        body {
            background: var(--bg-primary);
            color: var(--text-primary);
        }

        /* REMOVE old .nav-header — Navigation.astro handles this */

        .story-content :global(p) {
            margin-bottom: 1.5rem;
            line-height: 1.8;
            font-family: var(--serif);
            font-size: 1.125rem;
            color: var(--text-primary);
        }

        .story-content :global(p:first-of-type::first-letter) {
            font-size: 3.5rem;
            line-height: 1;
            float: left;
            margin-right: 0.5rem;
            margin-top: 0.25rem;
            color: var(--accent-blue);
        }

        .story-content :global(p:last-child) {
            margin-bottom: 0;
        }

        /* Prev/Next Navigation */
        .story-nav {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
            margin-top: 4rem;
            padding-top: 3rem;
            border-top: 1px solid var(--border-subtle);
        }

        .story-nav-link {
            padding: 1.5rem;
            border: 1px solid var(--border-subtle);
            text-decoration: none;
            transition: all 0.2s;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .story-nav-link:hover {
            border-color: var(--text-secondary);
            transform: translateY(-2px);
        }

        .story-nav-label {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .story-nav-title {
            font-family: var(--serif);
            font-size: 1.125rem;
            font-weight: 300;
            color: var(--text-primary);
        }

        .story-nav-link.next {
            text-align: right;
        }

        .story-nav-link.next .story-nav-label {
            justify-content: flex-end;
        }

        @media (max-width: 640px) {
            .story-nav {
                grid-template-columns: 1fr;
                gap: 1rem;
            }

            .story-nav-link.next {
                text-align: left;
            }

            .story-nav-link.next .story-nav-label {
                justify-content: flex-start;
            }
        }
    </style>
</head>

<body class="antialiased min-h-screen">

    <Navigation />

    <article class="pt-32 pb-24">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-12">

            {story.data.image && (
                <div class="aspect-[16/9] mb-12 overflow-hidden"
                     style="background: var(--bg-accent); border: 1px solid var(--border-subtle);">
                    <img 
                        src={story.data.image}
                        alt={story.data.title}
                        class="w-full h-full object-cover opacity-90"
                    />
                </div>
            )}

            <header class="mb-16 max-w-2xl mx-auto">
                <div class="flex items-center gap-4 text-xs uppercase tracking-widest mb-6 font-light"
                     style="color: var(--text-muted);">
                    <time>
                        {story.data.date.toLocaleDateString('en-US', {
                            year: 'numeric',
                            month: 'long',
                            day: 'numeric'
                        })}
                    </time>

                    {story.data.readTime && (
                        <>
                            <span>·</span>
                            <span>{story.data.readTime}</span>
                        </>
                    )}
                </div>

                <h1 class="text-3xl md:text-5xl font-light leading-tight"
                    style="font-family: var(--serif); color: var(--text-primary);">
                    {story.data.title}
                </h1>
            </header>

            <div class="story-content max-w-2xl mx-auto" set:html={story.body} />

            <!-- Previous / Next Navigation -->
            <nav class="story-nav max-w-2xl mx-auto">

                {prevStory ? (
                    <a href={`/stories/${prevStory.slug}`} class="story-nav-link prev">
                        <span class="story-nav-label">
                            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M15 19l-7-7 7-7"/>
                            </svg>
                            Previous
                        </span>
                        <span class="story-nav-title">{prevStory.data.title}</span>
                    </a>
                ) : <div></div>}

                {nextStory ? (
                    <a href={`/stories/${nextStory.slug}`} class="story-nav-link next">
                        <span class="story-nav-label">
                            Next
                            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M9 5l7 7-7 7"/>
                            </svg>
                        </span>
                        <span class="story-nav-title">{nextStory.data.title}</span>
                    </a>
                ) : <div></div>}

            </nav>

        </div>
    </article>

    <Newsletter />

    <footer class="py-12" style="border-top: 1px solid var(--border-subtle);">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-12">
            <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-sm font-light"
                 style="color: var(--text-muted);">
                <div class="flex items-center gap-2">
                    <p>© 2017-{new Date().getFullYear()} · All Rights Reserved</p>
                    <span>·</span>
                    <a href="/copyright" class="transition-colors"
                       style="color: var(--text-muted);"
                       onmouseover="this.style.color='var(--text-primary)'"
                       onmouseout="this.style.color='var(--text-muted)'">
                        Copyright Policy
                    </a>
                </div>
                <p>Inaayat</p>
            </div>
        </div>
    </footer>

    <ScrollToTop />

</body>
</html>
