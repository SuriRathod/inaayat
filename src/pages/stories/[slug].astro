---
import { getCollection } from 'astro:content';
import '../../styles/global.css';
import SEO from '../../components/SEO.astro';
import ScrollToTop from '../../components/ScrollToTop.astro';

export async function getStaticPaths() {
  const stories = await getCollection('stories');
  return stories.map((story) => ({
    params: { slug: story.slug },
    props: { story },
  }));
}

const { story } = Astro.props;
const { Content } = await story.render();
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <SEO 
      title={story.data.title}
      description={story.data.excerpt.substring(0, 160)}
      image={story.data.image}
      type="article"
      publishedTime={story.data.date}
      author="Suri Rathod"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <style>
        body {
            background: var(--bg-primary);
            color: var(--text-primary);
        }
        
        .nav-header {
            background: rgba(15, 20, 25, 0.8);
            border-bottom: 1px solid var(--border-subtle);
        }
        
        .story-content :global(p) {
            margin-bottom: 1.5rem;
            line-height: 1.8;
            font-family: var(--serif);
            font-size: 1.125rem;
            color: var(--text-primary);
        }
        
        .story-content :global(p:first-of-type::first-letter) {
            font-size: 3.5rem;
            line-height: 1;
            float: left;
            margin-right: 0.5rem;
            margin-top: 0.25rem;
            color: var(--accent-blue);
        }
        
        .story-content :global(p:last-child) {
            margin-bottom: 0;
        }
    </style>
</head>
<body class="antialiased min-h-screen">
    
    <header class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md nav-header">
        <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-12">
            <div class="flex justify-between items-center h-16 sm:h-20">
                <a href="/" class="text-lg sm:text-xl font-light tracking-widest" style="font-family: var(--serif); color: var(--text-primary);">
                    INAAYAT
                </a>
                <a href="/stories" class="text-xs sm:text-sm transition-colors inline-flex items-center gap-2" style="color: var(--text-secondary);" onmouseover="this.style.color='var(--text-primary)'" onmouseout="this.style.color='var(--text-secondary)'">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7"/>
                    </svg>
                    All Stories
                </a>
            </div>
        </nav>
    </header>

    <article class="pt-32 pb-24">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-12">
            
            {story.data.image && (
                <div class="aspect-[16/9] mb-12 overflow-hidden" style="background: var(--bg-accent); border: 1px solid var(--border-subtle);">
                    <img 
                        src={story.data.image}
                        alt={story.data.title}
                        class="w-full h-full object-cover opacity-90"
                    />
                </div>
            )}
            
            <header class="mb-16 max-w-2xl mx-auto">
                <div class="flex items-center gap-4 text-xs uppercase tracking-widest mb-6 font-light" style="color: var(--text-muted);">
                    <time>
                        {story.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                    </time>
                    {story.data.readTime && (
                        <>
                            <span>·</span>
                            <span>{story.data.readTime}</span>
                        </>
                    )}
                </div>
                <h1 class="text-3xl md:text-5xl font-light leading-tight" style="font-family: var(--serif); color: var(--text-primary);">
                    {story.data.title}
                </h1>
            </header>
            
            <div class="story-content max-w-2xl mx-auto" set:html={story.body} />
            
        </div>
    </article>

    <footer class="py-12" style="border-top: 1px solid var(--border-subtle);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-12">
        <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-sm font-light" style="color: var(--text-muted);">
            <div class="flex items-center gap-2">
                <p>© 2017-{new Date().getFullYear()} · All Rights Reserved</p>
                <span>·</span>
                <a href="/copyright" class="transition-colors" style="color: var(--text-muted);" onmouseover="this.style.color='var(--text-primary)'" onmouseout="this.style.color='var(--text-muted)'">Copyright Policy</a>
            </div>
            <p>Inaayat</p>
        </div>
    </div>
</footer>

    <ScrollToTop />

</body>
</html>